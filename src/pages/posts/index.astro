---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const allPosts = await getCollection('posts');
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ['AI', 'DevOps', 'Trading', 'Tinkering'] as const;
const byCategory = Object.fromEntries(
  categories.map((cat) => [cat, allPosts.filter((p) => p.data.category === cat)])
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>All Posts — Abedis Lab</title>
    <meta name="description" content="Hard things, drawn simple. Every post by topic." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="wrap site-head">
      <a href="/" class="logo">Abedis<span class="logo-dot">.</span>Lab</a>
      <nav>
        <a href="/#topics">Topics</a>
        <a href="/#why">Why</a>
        <a href="/posts" aria-current="page">Posts</a>
      </nav>
    </header>

    <main class="wrap posts-index">
      <h1>All posts</h1>

      {categories.map((cat) => byCategory[cat].length > 0 && (
        <section class="category-group" id={cat.toLowerCase()}>
          <h2 class="category-heading">
            <span class="category-badge">{cat}</span>
          </h2>
          <ul class="post-list">
            {byCategory[cat].map((post) => {
              const dateStr = post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric', month: 'long', day: 'numeric',
              });
              return (
                <li>
                  <a href={`/posts/${post.id}`} class="post-card">
                    <div class="post-card-meta">
                      <span class="muted">{post.data.readingTime} min read</span>
                      <span class="meta-dot" aria-hidden="true">·</span>
                      <time datetime={post.data.pubDate.toISOString()} class="muted">{dateStr}</time>
                    </div>
                    <h3 class="post-card-title">{post.data.title}</h3>
                    <p class="post-card-gist">{post.data.gist}</p>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </main>

    <footer class="wrap site-foot">
      <span>Abedis Lab</span>
      <span class="social-links">
        <a href="https://www.instagram.com/litbulbnet/" target="_blank" rel="noopener noreferrer">@litbulbnet</a>
        <span class="muted" aria-hidden="true">·</span>
        <a href="https://x.com/abedislab" target="_blank" rel="noopener noreferrer">@abedislab</a>
      </span>
    </footer>
  </body>
</html>

<style>
  .site-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.5rem;
  }
  .logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.3rem;
    text-decoration: none;
    color: var(--ink);
  }
  .logo-dot { color: var(--accent); }
  nav a {
    margin-left: 1.5rem;
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 700;
  }
  nav a:hover, nav a[aria-current] { color: var(--accent); }

  .posts-index { padding-block: clamp(2rem, 6vw, 4rem); }

  h1 {
    font-size: clamp(2.2rem, 6vw, 4rem);
    margin: 0 0 3rem;
  }

  .category-group { margin-bottom: 3.5rem; }

  .category-heading { margin: 0 0 1.25rem; }

  .category-badge {
    background: var(--accent-soft);
    color: var(--accent);
    padding: 0.2rem 0.8rem;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-body);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: block;
    background: var(--paper-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .post-card-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }
  .muted { color: var(--ink-soft); }
  .meta-dot { color: var(--line); }

  .post-card-title {
    font-size: 1.3rem;
    margin: 0 0 0.5rem;
    color: var(--ink);
  }

  .post-card-gist {
    color: var(--ink-soft);
    margin: 0;
    font-size: 0.95rem;
    max-width: var(--measure);
  }

  .site-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 2.5rem;
    margin-top: clamp(2rem, 6vw, 5rem);
    border-top: 1px solid var(--line);
    font-weight: 700;
  }
  .social-links { display: flex; gap: 0.5rem; align-items: center; }
  .social-links a { color: var(--ink-soft); font-weight: 400; text-decoration: none; }
  .social-links a:hover { color: var(--accent); }
</style>
