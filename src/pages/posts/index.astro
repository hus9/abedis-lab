---
import '../../styles/global.css';
import SeoHead from '../../components/SeoHead.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { getPublishedPosts, isNew } from '../../lib/posts';

const allPosts = await getPublishedPosts();
const categories = ['AI', 'Tech', 'Trading', 'Tinkering'] as const;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>All Posts — Lit Bulb Lab</title>
    <meta name="description" content="Hard things, drawn simple. Every post, newest first." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SeoHead title="All Posts — Lit Bulb Lab" description="Hard things, drawn simple. Every post, newest first." />
  </head>
  <body>
    <header class="wrap site-head">
      <a href="/" class="logo">Lit Bulb Lab</a>
      <nav>
        <a href="/#topics">Topics</a>
        <a href="/#why">Why</a>
        <a href="/posts" aria-current="page">Posts</a>
        <ThemeToggle />
      </nav>
    </header>

    <main class="wrap posts-index">
      <h1>All posts</h1>

      <div class="filters" role="group" aria-label="Filter posts by topic">
        <button class="chip" data-filter="all" aria-pressed="true">All</button>
        {categories.map((cat) => (
          <button class="chip" data-filter={cat.toLowerCase()} aria-pressed="false">{cat}</button>
        ))}
      </div>

      <ul class="post-list">
        {allPosts.map((post) => {
          const dateStr = post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          return (
            <li data-category={post.data.category.toLowerCase()}>
              <a href={`/posts/${post.id}`} class="post-card">
                <div class="post-card-meta">
                  {isNew(post.data.pubDate) && <span class="new-badge">New</span>}
                  <span class="category-badge" data-category={post.data.category.toLowerCase()}>{post.data.category}</span>
                  {post.data.topic && <span class="topic-label">{post.data.topic}</span>}
                  <time datetime={post.data.pubDate.toISOString()} class="muted">{dateStr}</time>
                  <span class="meta-dot" aria-hidden="true">·</span>
                  <span class="muted">{post.data.readingTime} min read</span>
                </div>
                <h3 class="post-card-title">{post.data.title}</h3>
                <p class="post-card-gist">{post.data.gist}</p>
              </a>
            </li>
          );
        })}
      </ul>
    </main>

    <footer class="wrap site-foot">
      <span>Lit Bulb Lab</span>
      <span class="social-links">
        <a href="https://www.instagram.com/litbulblab/" target="_blank" rel="noopener noreferrer">@litbulblab</a>
        <span class="muted" aria-hidden="true">·</span>
        <a href="https://x.com/litbulblab" target="_blank" rel="noopener noreferrer">@litbulblab</a>
      </span>
    </footer>

    <script>
      // Category filter chips. Supports /posts#tech deep links (used by the
      // homepage topic cards) by activating the matching chip on load.
      const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
      const items = document.querySelectorAll<HTMLLIElement>('.post-list > li');

      function applyFilter(filter: string) {
        chips.forEach((c) => c.setAttribute('aria-pressed', String(c.dataset.filter === filter)));
        items.forEach((li) => {
          li.hidden = filter !== 'all' && li.dataset.category !== filter;
        });
      }

      chips.forEach((chip) =>
        chip.addEventListener('click', () => applyFilter(chip.dataset.filter!))
      );

      const hash = location.hash.slice(1).toLowerCase();
      if ([...chips].some((c) => c.dataset.filter === hash)) applyFilter(hash);
    </script>
  </body>
</html>

<style>
  .site-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.5rem;
  }
  .logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.3rem;
    text-decoration: none;
    color: var(--ink);
  }
  nav a {
    margin-left: 1.5rem;
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 700;
  }
  nav a:hover, nav a[aria-current] { color: var(--accent); }

  .posts-index { padding-block: clamp(2rem, 6vw, 4rem); }

  h1 {
    font-size: clamp(2.2rem, 6vw, 4rem);
    margin: 0 0 1.5rem;
  }

  .filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }
  .chip {
    background: var(--paper-raised);
    border: var(--border-w) solid var(--line);
    color: var(--ink-soft);
    padding: 0.45rem 1.1rem;
    border-radius: var(--radius-tag);
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); }
  .chip[aria-pressed="true"] {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .new-badge {
    background: var(--accent);
    color: #fff;
    padding: 0.2rem 0.7rem;
    border-radius: var(--radius-tag);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .category-badge {
    background: var(--accent-soft);
    color: var(--accent);
    padding: 0.2rem 0.8rem;
    border-radius: var(--radius-tag);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: block;
    background: var(--paper-raised);
    border: var(--card-border);
    border-radius: var(--radius);
    padding: 1.5rem 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  /* Fluid masonry is a light-mode affectation (see PRODUCT.md's
     Designspiration brief) — dark mode keeps its original single-column
     list untouched. */
  @media (prefers-color-scheme: light) {
    .post-list {
      display: block;
      columns: 3 18rem;
      column-gap: 2.25rem;
    }
    .post-list > li { break-inside: avoid; margin-bottom: 2.25rem; }
  }
  :root[data-theme="light"] .post-list {
    display: block;
    columns: 3 18rem;
    column-gap: 2.25rem;
  }
  :root[data-theme="light"] .post-list > li { break-inside: avoid; margin-bottom: 2.25rem; }
  :root[data-theme="dark"] .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }
  .muted { color: var(--ink-soft); }
  .topic-label { color: var(--ink-soft); font-weight: 700; }
  .meta-dot { color: var(--line); }

  .post-card-title {
    font-size: 1.4rem;
    margin: 0 0 0.5rem;
    color: var(--ink);
  }

  .post-card-gist {
    color: var(--ink-soft);
    margin: 0;
    font-size: 0.95rem;
    max-width: var(--measure);
  }

  .site-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 2.5rem;
    margin-top: clamp(2rem, 6vw, 5rem);
    border-top: var(--border-w) solid var(--line);
    font-weight: 700;
  }
  .social-links { display: flex; gap: 0.5rem; align-items: center; }
  .social-links a { color: var(--ink-soft); font-weight: 400; text-decoration: none; }
  .social-links a:hover { color: var(--accent); }
</style>
