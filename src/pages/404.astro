---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { getPublishedPosts } from '../lib/posts';

const [latest] = await getPublishedPosts();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found — Lit Bulb Lab</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="wrap site-head">
      <a href="/" class="logo">Lit Bulb Lab</a>
      <nav>
        <a href="/#topics">Topics</a>
        <a href="/#why">Why</a>
        <a href="/posts">Posts</a>
        <ThemeToggle />
      </nav>
    </header>

    <main class="wrap not-found">
      <p class="eyebrow">404</p>
      <h1>This bulb isn't lit.</h1>
      <p class="lede">The page you're after doesn't exist — it may have moved, or the link was mistyped.</p>
      <div class="options">
        <a class="cta" href="/posts">Browse all posts</a>
        {latest && <a class="soft-link" href={`/posts/${latest.id}`}>or read the latest: {latest.data.title}</a>}
      </div>
    </main>
  </body>
</html>

<style>
  .site-head {
    display: flex; justify-content: space-between; align-items: center;
    padding-block: 1.5rem;
  }
  .logo { font-family: var(--font-display); font-weight: 900; font-size: 1.3rem; text-decoration: none; color: var(--ink); }
  nav a { margin-left: 1.5rem; color: var(--ink-soft); text-decoration: none; font-weight: 700; }
  nav a:hover { color: var(--accent); }

  .not-found { padding-block: clamp(4rem, 15vh, 10rem); }
  .eyebrow {
    text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.8rem;
    font-weight: 700; color: var(--accent); margin: 0 0 1rem;
  }
  h1 { font-size: clamp(2.4rem, 7vw, 4.5rem); margin: 0 0 1rem; }
  .lede { font-size: 1.15rem; color: var(--ink-soft); font-family: var(--font-body); margin: 0 0 2.5rem; max-width: var(--measure); }
  .options { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .cta {
    display: inline-block; background: var(--accent); color: #fff;
    padding: 0.9rem 1.8rem; border-radius: var(--radius); font-weight: 700;
    text-decoration: none; transition: transform 0.15s ease;
  }
  .cta:hover { transform: translateY(-2px); }
  .soft-link { color: var(--ink-soft); font-weight: 700; text-decoration: none; }
  .soft-link:hover { color: var(--accent); }
</style>
