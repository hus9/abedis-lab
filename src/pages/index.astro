---
import { Image } from 'astro:assets';
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import { getPublishedPosts, getHero, isNew } from '../lib/posts';

const topics = [
  { name: 'AI', blurb: 'New tools, plain words. What it does, why it matters.', icon: '◆' },
  { name: 'Tech', blurb: 'Servers, pipelines, cloud. Drawn, not droned.', icon: '▲' },
  { name: 'Trading', blurb: 'Markets and automation without the jargon wall.', icon: '●' },
  { name: 'Tinkering', blurb: 'Gadgets, watches, cameras. The fun side of tech.', icon: '✦' },
];

const posts = await getPublishedPosts();
const [lead, ...rest] = posts;
const recent = rest.slice(0, 2);
const leadHero = lead && getHero(lead.id);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lit Bulb Lab · hard things, drawn simple</title>
    <meta name="description" content="Tech explained for brains that work differently. Visual, simple, calm." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SeoHead
      title="Lit Bulb Lab · hard things, drawn simple"
      description="Tech explained for brains that work differently. Visual, simple, calm."
    />
  </head>
  <body>
    <header class="wrap site-head">
      <span class="logo">Lit Bulb Lab</span>
      <nav>
        <a href="#topics">Topics</a>
        <a href="#why">Why</a>
        <a href="/posts">Posts</a>
      </nav>
    </header>

    <main>
      <section class="hero wrap">
        <p class="eyebrow">Tech, for brains that work differently</p>
        <h1>Hard things,<br /><span class="accent">drawn simple.</span></h1>
        <p class="lede">
          Short chunks. Real pictures. No jargon walls. Built for ADHD,
          dyslexia, and anyone new to the tech world.
        </p>
        {lead && <a class="cta" href={`/posts/${lead.id}`}>Read today's post</a>}
        <a class="cta-soft" href="#topics">See how it works</a>
      </section>

      {lead && (
        <section id="latest" class="wrap latest">
          <h2 class="section-title">Fresh from the lab</h2>
          <a href={`/posts/${lead.id}`} class="lead-post">
            {leadHero && (
              <Image src={leadHero} alt="" width={640} height={360} class="lead-thumb" />
            )}
            <div class="lead-text">
              <div class="lead-meta">
                {isNew(lead.data.pubDate) && <span class="new-badge">New</span>}
                <span class="category-badge">{lead.data.category}</span>
                {lead.data.topic && <span class="topic-label">{lead.data.topic}</span>}
                <time datetime={lead.data.pubDate.toISOString()} class="muted">{fmt(lead.data.pubDate)}</time>
                <span class="muted">· {lead.data.readingTime} min</span>
              </div>
              <h3>{lead.data.title}</h3>
              <p class="lead-gist">{lead.data.gist}</p>
            </div>
          </a>
          {recent.length > 0 && (
            <ul class="recent-list">
              {recent.map((p) => (
                <li>
                  <a href={`/posts/${p.id}`} class="recent-row">
                    <span class="recent-title">{p.data.title}</span>
                    <span class="recent-meta">
                      {p.data.topic && <span class="topic-label">{p.data.topic}</span>}
                      <span class="category-badge">{p.data.category}</span>
                      <time datetime={p.data.pubDate.toISOString()} class="muted">{fmt(p.data.pubDate)}</time>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )}
          <a class="all-posts-link" href="/posts">All posts →</a>
        </section>
      )}

      <section id="topics" class="wrap topics">
        <h2 class="section-title">Pick a corner</h2>
        <div class="grid">
          {topics.map((t) => (
            <a href={`/posts#${t.name.toLowerCase()}`} class="card">
              <span class="card-icon" aria-hidden="true">{t.icon}</span>
              <h3>{t.name}</h3>
              <p>{t.blurb}</p>
            </a>
          ))}
        </div>
      </section>

      <section id="why" class="wrap why">
        <h2 class="section-title">One idea per screen</h2>
        <div class="why-row">
          <div class="why-text">
            <p>
              Most tech writing assumes you can grind through a wall of text.
              We don't.
            </p>
            <ul class="ticks">
              <li>One concept at a time</li>
              <li>A picture before a paragraph</li>
              <li>A readable font, made for low vision</li>
              <li>Calm pacing, no rush, no noise</li>
            </ul>
          </div>
          <figure class="demo" aria-label="Example: a database explained in four lines">
            <div class="demo-row"><span>Table</span><b>= a sheet</b></div>
            <div class="demo-row"><span>Row</span><b>= one record</b></div>
            <div class="demo-row"><span>Column</span><b>= one field</b></div>
            <div class="demo-row"><span>Query</span><b>= a question</b></div>
            <figcaption>A database, in four lines.</figcaption>
          </figure>
        </div>
      </section>
    </main>

    <footer class="wrap site-foot">
      <span>Lit Bulb Lab</span>
      <span class="social-links">
        <a href="https://www.instagram.com/litbulblab/" target="_blank" rel="noopener noreferrer">@litbulblab</a>
        <span class="muted" aria-hidden="true">·</span>
        <a href="https://x.com/litbulblab" target="_blank" rel="noopener noreferrer">@litbulblab</a>
      </span>
    </footer>
  </body>
</html>

<style>
  .site-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.5rem;
  }
  .logo { font-family: var(--font-display); font-weight: 900; font-size: 1.3rem; }
  nav a { margin-left: 1.5rem; color: var(--ink-soft); text-decoration: none; font-weight: 700; }
  nav a:hover { color: var(--accent); }

  .hero { padding-block: clamp(3rem, 12vh, 8rem) var(--gap); }
  .eyebrow {
    text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.8rem;
    font-weight: 700; color: var(--accent); margin: 0 0 1rem;
  }
  h1 { font-size: clamp(2.8rem, 9vw, 6rem); margin: 0; }
  .accent { color: var(--accent); }
  .lede { font-size: 1.25rem; font-family: var(--font-body); color: var(--ink-soft); margin: 1.5rem 0 2.5rem; }
  .cta {
    display: inline-block; background: var(--accent); color: #fff;
    padding: 0.9rem 1.8rem; border-radius: var(--radius); font-weight: 700;
    text-decoration: none; transition: transform 0.15s ease;
  }
  .cta:hover { transform: translateY(-2px); }
  .cta-soft {
    display: inline-block; margin-left: 1rem; color: var(--ink-soft);
    font-weight: 700; text-decoration: none;
    padding: 0.9rem 0.5rem;
  }
  .cta-soft:hover { color: var(--accent); }

  .section-title { font-size: clamp(1.8rem, 4vw, 2.6rem); margin: 0 0 2rem; }

  .latest { padding-block: var(--gap); }
  .lead-post {
    display: grid; grid-template-columns: minmax(0, 5fr) minmax(0, 4fr);
    gap: clamp(1.5rem, 4vw, 3rem); align-items: center;
    text-decoration: none; color: inherit;
    background: var(--paper-raised); border: 1px solid var(--line);
    border-radius: var(--radius); padding: clamp(1.25rem, 3vw, 2rem);
    transition: border-color 0.15s;
  }
  .lead-post:hover { border-color: var(--accent); }
  .lead-post:hover h3 { color: var(--accent); }
  .lead-thumb {
    width: 100%; height: auto; border-radius: calc(var(--radius) - 6px);
    order: 2;
  }
  .lead-meta {
    display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    font-size: 0.85rem; font-weight: 700; margin-bottom: 0.75rem;
  }
  .new-badge {
    background: var(--accent); color: #fff;
    padding: 0.2rem 0.7rem; border-radius: 99px;
    font-size: 0.8rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .category-badge {
    background: var(--accent-soft); color: var(--accent);
    padding: 0.2rem 0.7rem; border-radius: 99px;
    font-size: 0.8rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .muted { color: var(--ink-soft); font-weight: 400; }
  .topic-label { color: var(--ink-soft); font-weight: 700; }
  .lead-text h3 {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem); margin: 0 0 0.75rem;
    transition: color 0.15s;
  }
  .lead-gist { color: var(--ink-soft); font-family: var(--font-body); margin: 0; }
  .recent-list { list-style: none; padding: 0; margin: 1.25rem 0 0; }
  .recent-row {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 1rem; padding: 1rem 0.25rem;
    border-bottom: 1px dashed var(--line);
    text-decoration: none; color: inherit;
  }
  .recent-row:hover .recent-title { color: var(--accent); }
  .recent-title { font-weight: 700; transition: color 0.15s; }
  .recent-meta { display: flex; align-items: baseline; gap: 0.6rem; flex-shrink: 0; font-size: 0.85rem; }
  .all-posts-link {
    display: inline-block; margin-top: 1.5rem;
    color: var(--accent); font-weight: 700; text-decoration: none;
  }
  .all-posts-link:hover { text-decoration: underline; }
  .topics { padding-block: var(--gap); }
  .grid {
    display: grid; gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }
  .card {
    background: var(--paper-raised); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 1.75rem;
    text-decoration: none; color: inherit; display: block;
    transition: border-color 0.15s, transform 0.15s;
  }
  .card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .card-icon { color: var(--accent); font-size: 1.4rem; }
  .card h3 { margin: 0.6rem 0 0.4rem; font-size: 1.4rem; }
  .card p { color: var(--ink-soft); margin: 0; }

  .why { padding-block: var(--gap); }
  .why-row { display: grid; gap: var(--gap); grid-template-columns: 1fr 1fr; align-items: center; }
  .why-text p { font-size: 1.2rem; }
  .ticks { list-style: none; padding: 0; margin: 1.5rem 0 0; }
  .ticks li { padding-left: 1.8rem; position: relative; margin-bottom: 0.75rem; font-weight: 700; }
  .ticks li::before {
    content: '✓'; position: absolute; left: 0; color: var(--good); font-weight: 900;
  }
  .demo {
    background: var(--paper-raised); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 1.5rem; margin: 0;
  }
  .demo-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.7rem 0; border-bottom: 1px dashed var(--line);
  }
  .demo-row span { color: var(--ink-soft); }
  .demo-row b { color: var(--accent); }
  .demo figcaption { margin-top: 1rem; color: var(--ink-soft); font-style: italic; }

  .site-foot {
    display: flex; justify-content: space-between;
    padding-block: 2.5rem; margin-top: var(--gap);
    border-top: 1px solid var(--line); font-weight: 700;
  }
  .muted { color: var(--ink-soft); font-weight: 400; }
  .social-links { display: flex; gap: 0.5rem; align-items: center; }
  .social-links a { color: var(--ink-soft); font-weight: 400; text-decoration: none; }
  .social-links a:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .why-row { grid-template-columns: 1fr; }
    .lead-post { grid-template-columns: 1fr; }
    .lead-thumb { order: 0; }
    .recent-row { flex-direction: column; gap: 0.35rem; }
  }
</style>
